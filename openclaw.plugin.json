{
  "id": "anban",
  "name": "Anban 智能创作助手",
  "description": "Anban Creator plugin for WeChat, Seednote, Montage, videocreator, videoeditor, ecommerce, and agent-assisted publishing workflows",
  "version": "2.7.43",
  "enabledByDefault": true,
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "skills": ["skills"],
  "mcp": {
    "creator": {
      "url": "${ANBAN_API_URL:-http://localhost:18060}/mcp",
      "transport": "streamable-http",
      "headers": {
        "Authorization": "Bearer ${ANBAN_API_KEY}"
      }
    }
  }
}
